# ─── Database (Neon PostgreSQL) ───────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─── Authentication ────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET="replace-with-strong-random-secret"

# ─── App URL ───────────────────────────────────────────────────────────────────
# Set to your production domain on Vercel (e.g. https://plus-one.vercel.app)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Payments (Razorpay) ───────────────────────────────────────────────────────
# Get from https://dashboard.razorpay.com → Settings → API Keys
# Use rzp_test_* for staging, rzp_live_* for production
RAZORPAY_KEY_ID="rzp_live_SYwLMUw8Xto9UZxx"
RAZORPAY_KEY_SECRET="Msg6v5vISVQYXuA8NFhfungM"

# ─── Real-time (Ably) ──────────────────────────────────────────────────────────
# Get from https://ably.com → Apps → API Keys
# Key must have: publish, subscribe, presence, history on all channels
ABLY_API_KEY="xxxxx.yyyyy:zzzzzzzzzzzz"

# ─── Image Storage (Cloudinary) ────────────────────────────────────────────────
# Get from https://console.cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME="dvykccci2"
CLOUDINARY_API_KEY="414911396726895"
CLOUDINARY_API_SECRET="XjkAYIwcAkgeHSBfAmUXD6LKgs0"

# ─── Voice Calls (Agora) ───────────────────────────────────────────────────────
# Get from https://console.agora.io → Project Management
AGORA_APP_ID="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
AGORA_APP_CERTIFICATE="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ─── Email (SMTP) — Optional ───────────────────────────────────────────────────
# If not set, emails are silently skipped (no crash). For Gmail use App Password.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-16-char-app-password"

# ─── Payments (Setu — UPI Collect / Payment Links) ────────────────────────────
# Get from https://bridge.setu.co → Products → UPI DeepLinks / Collect
# SETU_MODE controls which base URL is used: sandbox → uat.setu.co, production → prod.setu.co
SETU_CLIENT_ID=""
SETU_CLIENT_SECRET=""
SETU_SCHEME_ID=""
SETU_WEBHOOK_SECRET=""
SETU_MODE="sandbox"

# ─── Identity Verification (Setu OKYC — Aadhaar OTP) ──────────────────────────
# Get from https://bridge.setu.co → Products → OKYC
# Separate credentials from the UPI Collect product above
SETU_OKYC_CLIENT_ID=""
SETU_OKYC_CLIENT_SECRET=""
SETU_OKYC_PRODUCT_INSTANCE_ID=""

# ─── Web Push (VAPID) ─────────────────────────────────────────────────────────
# Generate with: node scripts/generate-vapid.js
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@plusone.app"

# ─── Firebase Cloud Messaging (FCM) ──────────────────────────────────────────
# Client-side (exposed to browser — safe to commit)
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
NEXT_PUBLIC_FIREBASE_VAPID_KEY=""          # Web Push certificate key from Firebase Console

# Server-side (service account JSON — keep secret)
FIREBASE_SERVICE_ACCOUNT=""                # Full JSON string of the Firebase service account

# ─── Runtime ───────────────────────────────────────────────────────────────────
# Set automatically by Vercel — do not set manually in production
# NODE_ENV="production"
