DATABASE_URL="postgresql://neondb_owner:npg_HF2IrTjYlnK0@ep-old-hat-a1aj6e5o-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Authentication (Generate a strong secret for production: openssl rand -base64 32)
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# App URL (Update to your production domain)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Payment - Razorpay (Required for subscriptions)
# Get from https://dashboard.razorpay.com/
RAZORPAY_KEY_ID=dummy
RAZORPAY_KEY_SECRET=dummy

# Email - SMTP (Required for notifications)
# For Gmail: Use App Password, not your regular password
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# Security (Generate: openssl rand -base64 32)
ENCRYPTION_KEY="your-32-char-encryption-key-here"

# Environment
NODE_ENV="production"

# Optional: Analytics
