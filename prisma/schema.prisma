generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum ClientStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum AvailabilityStatus {
  ONLINE
  BUSY
  OFFLINE
}

enum BookingType {
  IN_PERSON
  VIRTUAL
}

enum SetuStatus {
  PENDING
  COMPLETED
  FAILED
  EXPIRED
}

enum SubscriptionStatus {
  FREE
  ACTIVE
  EXPIRED
  CANCELLED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id               String                @id @default(cuid())
  email            String                @unique
  passwordHash     String
  role             String                @default("CLIENT")
  isActive         Boolean               @default(true)
  isBanned         Boolean               @default(false)
  subscriptionTier      String             @default("FREE")
  subscriptionStatus    SubscriptionStatus @default(FREE)
  subscriptionExpiresAt DateTime?
  subscriptionPlan      String?            // e.g. "MONTHLY_2999"
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  // Client onboarding fields
  clientStatus     ClientStatus          @default(APPROVED)
  // APPROVED default ensures all existing users are not locked out on deploy
  adminApprovedAt  DateTime?             // set when admin approves; client gets access 8h later
  linkedInUrl      String?
  phone            String?
  rejectionReason  String?
  setuOkycRefId    String?               // Setu OKYC verification reference ID

  // Companion fields
  isTemporaryPassword    Boolean         @default(false)
  hasCompletedOnboarding Boolean         @default(false)
  isOnline               Boolean         @default(false)

  // Location fields
  latitude            Float?
  longitude           Float?
  locationUpdatedAt   DateTime?

  // Relations
  clientProfile    ClientProfile?
  companionProfile CompanionProfile?
  sentMessages     Message[]             @relation("SenderMessages")
  receivedMessages Message[]             @relation("ReceiverMessages")
  clientBookings   Booking[]             @relation("ClientBookings")
  companionBookings Booking[]            @relation("CompanionBookings")
  favorites        Favorite[]            @relation("ClientFavorites")
  favoritedBy      Favorite[]            @relation("CompanionFavorites")
  messageThreads   MessageThread[]       @relation("ClientThreads")
  companionThreads MessageThread[]       @relation("CompanionThreads")
  reviewsReceived  Review[]              @relation("ReviewedUser")
  reviewsGiven     Review[]              @relation("Reviewer")
  notifications    Notification[]
  emergencyContact EmergencyContact?
  checkIns         CheckIn[]             @relation("UserCheckIns")
  checkInAlerts    CheckIn[]             @relation("CompanionCheckIns")
  verificationDocs VerificationDocument[]
  payments                 Payment[]
  wallet                   Wallet?
  clientBillingSessions    BillingSession[]  @relation("ClientBillingSessions")
  companionBillingSessions BillingSession[]  @relation("CompanionBillingSessions")
  companionImages          CompanionImage[]
  blockedByCompanion       BlockedUser[]     @relation("BlockedCompanion")
  blockedClients           BlockedUser[]     @relation("BlockedClient")
  setuPayments             SetuPayment[]
  clientProfileViews       CompanionProfileView[] @relation("ClientViews")
  companionProfileViews    CompanionProfileView[] @relation("CompanionViews")
  pushSubscriptions        PushSubscription[]
  fcmTokens                FcmToken[]
  withdrawalRequests       WithdrawalRequest[]
  manualPayments           ManualPayment[]
  companionVisibility      ClientVisibility[]    @relation("CompanionVisibility")
  clientVisibility         ClientVisibility[]    @relation("ClientVisibility")
  clientScheduledSessions     ScheduledSession[]    @relation("ClientScheduledSessions")
  companionScheduledSessions  ScheduledSession[]    @relation("CompanionScheduledSessions")

  @@index([role, isActive, isBanned])
  @@index([isOnline])                     // auto-offline checks, presence queries
  @@index([createdAt])                    // "new companions" section sorting
}

model ClientProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String
  bio              String?
  avatarUrl        String?
  avatarStatus     String   @default("NONE")  // NONE | PENDING | APPROVED | REJECTED
  phone            String?
  lat              Float    @default(28.6139)
  lng              Float    @default(77.2090)
  occupation       String?
  city             String?
  dateOfBirth      DateTime?
  govtIdUrl        String?              // Cloudinary URL of uploaded government ID
  additionalNotes  String?              // Client's response to admin info requests
  shareItinerary   Boolean  @default(false)
  trustedContact   String?
  trustedContactPhone String?
}

model CompanionProfile {
  id               String              @id @default(cuid())
  userId           String              @unique
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String
  bio              String?
  tagline          String?
  avatarUrl        String?
  images           String              @default("[]")  // JSON array of image URLs (legacy)
  hourlyRate       Int                 @default(200000) // paise (₹2000/hr default)
  chatRatePerMinute Int?               @default(2000)  // paise per minute for chat (₹20/min default)
  callRatePerMinute Int?               @default(3200)  // paise per minute for voice calls (₹32/min default)
  tags             String              @default("[]")  // JSON array of tags
  isApproved       Boolean             @default(false)
  isVerified       Boolean             @default(false)
  lat              Float               @default(28.6139)
  lng              Float               @default(77.2090)
  availability     String              @default("[]")  // legacy — kept for compatibility
  availabilityStatus AvailabilityStatus @default(OFFLINE)
  gender           String?
  age              Int?
  languages        String              @default("[]")
  interests        String              @default("[]")
  verificationStatus String            @default("PENDING")
  averageRating    Float               @default(0)
  reviewCount      Int                 @default(0)
  city             String?

  // Extended profile fields
  height           String?
  weight           String?
  bodyType         String?
  hairColor        String?
  eyeColor         String?
  ethnicity        String?
  foodPreference   String?
  drinking         String?
  smoking          String?
  education        String?
  occupation       String?
  personalityTags  String              @default("[]") // JSON array

  // Weekly availability: JSON map of day → time slots
  // e.g. {"mon":["MORNING","AFTERNOON"],"tue":["EVENING"],...}
  weeklyAvailability String            @default("{}")
  availableNow       Boolean           @default(false)

  // Premium platform fields — ranking, trust, and quality signals
  audioIntroUrl      String?                          // Cloudinary URL for 15s audio intro
  introVideoUrl      String?                          // Cloudinary URL for short intro video
  rankingScore       Float             @default(0)    // precomputed 0-100, used for browse sort
  avgResponseTime    Int?                             // seconds, rolling avg of last 50 session acceptances
  totalRatedSessions Int               @default(0)    // sessions that received a rating
  lastSessionAt      DateTime?                        // last completed session timestamp
  profileComplete    Boolean           @default(false) // has audio + photos + bio

  // Relations
  badges             CompanionBadge[]

  @@index([rankingScore])
  @@index([availableNow, rankingScore])
  @@index([isApproved, availableNow])
}

model MessageThread {
  id           String    @id @default(cuid())
  clientId     String
  companionId  String
  client       User      @relation("ClientThreads", fields: [clientId], references: [id])
  companion    User      @relation("CompanionThreads", fields: [companionId], references: [id])
  messageCount Int       @default(0)
  isLocked     Boolean   @default(false) // kept in schema; no longer enforced in code
  messages     Message[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([clientId, companionId])
  @@index([clientId])
  @@index([companionId])
}

model Message {
  id         String        @id @default(cuid())
  threadId   String
  thread     MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  senderId   String
  receiverId String
  sender     User          @relation("SenderMessages", fields: [senderId], references: [id])
  receiver   User          @relation("ReceiverMessages", fields: [receiverId], references: [id])
  content    String
  isRead     Boolean       @default(false)
  createdAt  DateTime      @default(now())

  @@index([threadId, createdAt])
}

model Booking {
  id            String      @id @default(cuid())
  clientId      String
  companionId   String
  client        User        @relation("ClientBookings", fields: [clientId], references: [id])
  companion     User        @relation("CompanionBookings", fields: [companionId], references: [id])
  date          DateTime
  duration      Int         @default(2)           // hours
  bookingType   BookingType @default(VIRTUAL)
  status        String      @default("PENDING")   // PENDING | CONFIRMED | REJECTED | COMPLETED | EXPIRED | CANCELLED
  totalAmount   Int                               // paise
  depositAmount Int         @default(0)           // paise
  holdTransactionId String?                       // WalletTransaction.id for the HOLD record
  paymentStatus String      @default("PENDING")
  paymentId     String?
  notes         String?
  location      String?
  venueName     String?
  venueAddress  String?
  venueLat      Float?
  venueLng      Float?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  review        Review?
}

model Favorite {
  id          String   @id @default(cuid())
  clientId    String
  companionId String
  client      User     @relation("ClientFavorites", fields: [clientId], references: [id], onDelete: Cascade)
  companion   User     @relation("CompanionFavorites", fields: [companionId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([clientId, companionId])
  @@index([clientId])
}

model Review {
  id               String          @id @default(cuid())
  bookingId        String?         @unique   // nullable — set for booking reviews
  booking          Booking?        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  billingSessionId String?         @unique   // nullable — set for chat/voice session reviews
  billingSession   BillingSession? @relation(fields: [billingSessionId], references: [id], onDelete: Cascade)
  reviewerId       String
  reviewedId       String
  reviewer         User            @relation("Reviewer", fields: [reviewerId], references: [id])
  reviewed         User            @relation("ReviewedUser", fields: [reviewedId], references: [id])
  rating           Int
  comment          String?
  isPublic         Boolean         @default(true)
  createdAt        DateTime        @default(now())

  @@index([reviewedId])
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String
  title       String
  message     String
  data        String?  @default("{}")
  isRead      Boolean  @default(false)
  emailSent   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId, isRead])
}

model EmergencyContact {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  phone       String
  relationship String
  createdAt   DateTime @default(now())
}

model CheckIn {
  id            String    @id @default(cuid())
  userId        String
  companionId   String
  user          User      @relation("UserCheckIns", fields: [userId], references: [id], onDelete: Cascade)
  companion     User      @relation("CompanionCheckIns", fields: [companionId], references: [id], onDelete: Cascade)
  bookingId     String?
  scheduledAt   DateTime
  checkedInAt   DateTime?
  status        String    @default("SCHEDULED")
  location      String?
  notes         String?
  alertTriggered Boolean  @default(false)
  createdAt     DateTime  @default(now())
}

model VerificationDocument {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          String
  documentUrl   String
  status        String   @default("PENDING")
  adminNotes    String?
  submittedAt   DateTime @default(now())
  reviewedAt    DateTime?
}

model BillingSession {
  id              String    @id @default(cuid())
  clientId        String
  companionId     String
  client          User      @relation("ClientBillingSessions", fields: [clientId], references: [id])
  companion       User      @relation("CompanionBillingSessions", fields: [companionId], references: [id])
  type            String    @default("CHAT")    // CHAT | VOICE
  ratePerMinute   Int                           // paise/min — snapshot at session start
  status          String    @default("ACTIVE")  // PENDING | ACTIVE | ENDED | DECLINED | EXPIRED
  startedAt       DateTime?                     // null until companion accepts (CHAT) or immediately (VOICE)
  endedAt         DateTime?
  lastTickAt      DateTime  @default(now())
  totalMinutes    Float     @default(0)
  durationSeconds Int       @default(0)
  totalCharged    Int       @default(0)         // paise — total debited from client
  companionShare  Int       @default(0)         // paise — companion's 40% cut of totalCharged (accumulated per tick)
  expiresAt       DateTime?                     // PENDING requests expire at this time
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  review          Review?
  scheduledSession ScheduledSession?

  @@index([clientId, status])
  @@index([companionId, status])
  @@index([status, lastTickAt])              // for billing sweep cron
}

model Wallet {
  id           String              @id @default(cuid())
  userId       String              @unique
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance      Int                 @default(0) // paise
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  transactions WalletTransaction[]
}

model WalletTransaction {
  id           String   @id @default(cuid())
  walletId     String
  wallet       Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  // type values: RECHARGE | DEBIT | REFUND | HOLD | HOLD_RELEASE
  type         String
  amount       Int                // paise; always positive — type indicates direction
  balanceAfter Int                // paise snapshot at transaction time
  description  String
  metadata     String?  @default("{}")
  createdAt    DateTime @default(now())

  @@index([walletId, createdAt])
  @@index([walletId, type, createdAt])    // earnings breakdown by type
}

model CompanionImage {
  id          String   @id @default(cuid())
  companionId String
  imageUrl    String
  publicId    String?
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())
  companion   User     @relation(fields: [companionId], references: [id], onDelete: Cascade)

  @@index([companionId])
}

model BlockedUser {
  id          String   @id @default(cuid())
  companionId String
  clientId    String
  companion   User     @relation("BlockedCompanion", fields: [companionId], references: [id], onDelete: Cascade)
  client      User     @relation("BlockedClient", fields: [clientId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([companionId, clientId])
  @@index([companionId])
}

model Payment {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          String
  amount        Float    // kept as Float for legacy Razorpay amounts (not migrated)
  currency      String   @default("INR")
  status        String   @default("PENDING")
  razorpayOrderId    String?   @unique
  razorpayPaymentId  String?
  razorpaySignature  String?
  bookingId     String?
  metadata      String?  @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CompanionProfileView {
  id          String   @id @default(cuid())
  clientId    String
  companionId String   // User.id of the companion
  viewedAt    DateTime @default(now())
  durationMs  Int      @default(0)

  client    User @relation("ClientViews",    fields: [clientId],    references: [id], onDelete: Cascade)
  companion User @relation("CompanionViews", fields: [companionId], references: [id], onDelete: Cascade)

  @@index([clientId, companionId])
  @@index([clientId, viewedAt])
  @@index([companionId, viewedAt])        // companion analytics queries
}

model SetuPayment {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  setuPaymentId String      @unique
  amount        Int                     // paise
  status        SetuStatus  @default(PENDING)
  upiLink       String?
  qrCode        String?
  shortUrl      String?
  expiresAt     DateTime
  metadata      Json?
  createdAt     DateTime    @default(now())
  completedAt   DateTime?
}

model PushSubscription {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint   String   @unique
  p256dh     String
  auth       String
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([userId])
}

model FcmToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  device    String?  // user-agent or device identifier
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

model WithdrawalRequest {
  id          String           @id @default(cuid())
  companionId String
  companion   User             @relation(fields: [companionId], references: [id], onDelete: Cascade)
  amount      Int              // paise
  status      WithdrawalStatus @default(PENDING)
  note        String?
  adminNote   String?
  createdAt   DateTime         @default(now())
  resolvedAt  DateTime?

  @@index([companionId])
  @@index([status])
}

model ManualPayment {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  requestedAmount Int      // paise — what client wanted (e.g. 50000 = ₹500)
  uniqueAmount    Int      // paise — adjusted amount client actually pays (e.g. 49996 = ₹499.96)
  status          String   @default("PENDING") // PENDING | APPROVED | REJECTED | EXPIRED
  type            String   @default("WALLET")  // WALLET | SUBSCRIPTION
  upiId           String   // merchant UPI ID
  adminNote       String?
  createdAt       DateTime @default(now())
  expiresAt       DateTime // 15 minutes from creation
  resolvedAt      DateTime?

  @@index([userId, status])
  @@index([uniqueAmount, status])
  @@index([status, createdAt])
}

// ─── Client Visibility ──────────────────────────────────────────────────────
// Each companion can approve or reject individual clients. A client's profile
// is only shown to them after the companion has approved the client. This
// protects companion privacy — people who know the companion IRL can't see
// their profile unless the companion explicitly allows it.
model ClientVisibility {
  id          String   @id @default(cuid())
  companionId String
  clientId    String
  companion   User     @relation("CompanionVisibility", fields: [companionId], references: [id], onDelete: Cascade)
  client      User     @relation("ClientVisibility", fields: [clientId], references: [id], onDelete: Cascade)
  status      String   @default("PENDING") // PENDING | APPROVED | REJECTED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([companionId, clientId])
  @@index([companionId, status])
  @@index([clientId, status])
}

// ─── Scheduled Sessions ─────────────────────────────────────────────────────
// Pre-booked chat sessions with 30% wallet hold. Available to all users.
// Hold is forfeited on client no-show, released on companion no-show or cancel.
model ScheduledSession {
  id               String    @id @default(cuid())
  clientId         String
  companionId      String
  client           User      @relation("ClientScheduledSessions", fields: [clientId], references: [id])
  companion        User      @relation("CompanionScheduledSessions", fields: [companionId], references: [id])
  duration         Int                           // 15 or 30 minutes
  ratePerMinute    Int                           // paise — snapshot at booking time
  estimatedTotal   Int                           // paise — ratePerMinute × duration
  holdAmount       Int                           // paise — 30% of estimatedTotal
  holdTransactionId String?                      // WalletTransaction.id for the HOLD debit
  scheduledAt      DateTime                      // when session should start
  status           String    @default("BOOKED")  // BOOKED | ACTIVE | COMPLETED | CANCELLED | CLIENT_NO_SHOW | COMPANION_NO_SHOW
  billingSessionId String?   @unique             // linked BillingSession once activated
  billingSession   BillingSession?   @relation(fields: [billingSessionId], references: [id])
  cancelledBy      String?                       // CLIENT | COMPANION
  cancelledAt      DateTime?
  resolvedAt       DateTime?                     // when no-show was resolved
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([clientId, status])
  @@index([companionId, status])
  @@index([scheduledAt, status])
  @@index([status])
}

// ─── Companion Badges ───────────────────────────────────────────────────────
// Earned badges based on quality, responsiveness, and tenure. Recalculated daily.
model CompanionBadge {
  id            String           @id @default(cuid())
  companionId   String
  companion     CompanionProfile @relation(fields: [companionId], references: [userId], onDelete: Cascade)
  type          String           // TOP_RATED | FAST_RESPONDER | ELITE | RISING_STAR
  earnedAt      DateTime         @default(now())
  lostAt        DateTime?        // null = currently active
  isActive      Boolean          @default(true)

  @@unique([companionId, type])
  @@index([companionId, isActive])
}

// Immutable audit trail for admin actions. Every privileged mutation (ban,
// approve, reject, payout, etc.) should append a row here so we can
// reconstruct "who did what, when, to whom, and why" after the fact.
//
// Deliberately NOT tied to the admin User via FK cascade — if an admin
// account is later deleted, their audit history must still be readable.
model AdminAuditLog {
  id         String   @id @default(cuid())
  adminId    String   // User.id of the acting admin (no FK cascade by design)
  action     String   // e.g. "USER_BAN", "PAYMENT_APPROVE", "WITHDRAWAL_PAY"
  targetType String   // e.g. "User", "ManualPayment", "WithdrawalRequest"
  targetId   String   // primary key of the affected row
  reason     String?  // optional admin-supplied justification
  metadata   String?  @default("{}") // JSON blob for action-specific context
  createdAt  DateTime @default(now())

  @@index([adminId, createdAt])
  @@index([targetType, targetId])
  @@index([action, createdAt])
}
